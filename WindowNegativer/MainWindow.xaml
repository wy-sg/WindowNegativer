<Window x:Class="WindowNegativer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowNegativer"
        mc:Ignorable="d"
        Title="Window Negativer" Height="400" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MinWidth="100" MinHeight="80">
    <Grid>
        <!-- Resize grips (outer edges) -->
        <Rectangle x:Name="ResizeTop" Fill="Transparent" Height="5" VerticalAlignment="Top"
                   Cursor="SizeNS" MouseLeftButtonDown="Resize_MouseDown" Tag="Top"/>
        <Rectangle x:Name="ResizeBottom" Fill="Transparent" Height="5" VerticalAlignment="Bottom"
                   Cursor="SizeNS" MouseLeftButtonDown="Resize_MouseDown" Tag="Bottom"/>
        <Rectangle x:Name="ResizeLeft" Fill="Transparent" Width="5" HorizontalAlignment="Left"
                   Cursor="SizeWE" MouseLeftButtonDown="Resize_MouseDown" Tag="Left"/>
        <Rectangle x:Name="ResizeRight" Fill="Transparent" Width="5" HorizontalAlignment="Right"
                   Cursor="SizeWE" MouseLeftButtonDown="Resize_MouseDown" Tag="Right"/>
        <Rectangle x:Name="ResizeTopLeft" Fill="Transparent" Width="8" Height="8"
                   VerticalAlignment="Top" HorizontalAlignment="Left"
                   Cursor="SizeNWSE" MouseLeftButtonDown="Resize_MouseDown" Tag="TopLeft"/>
        <Rectangle x:Name="ResizeTopRight" Fill="Transparent" Width="8" Height="8"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Cursor="SizeNESW" MouseLeftButtonDown="Resize_MouseDown" Tag="TopRight"/>
        <Rectangle x:Name="ResizeBottomLeft" Fill="Transparent" Width="8" Height="8"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Cursor="SizeNESW" MouseLeftButtonDown="Resize_MouseDown" Tag="BottomLeft"/>
        <Rectangle x:Name="ResizeBottomRight" Fill="Transparent" Width="8" Height="8"
                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                   Cursor="SizeNWSE" MouseLeftButtonDown="Resize_MouseDown" Tag="BottomRight"/>

        <!-- Title bar -->
        <Border Height="28" VerticalAlignment="Top" Background="#DD222222"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                MouseMove="TitleBar_MouseMove"
                MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
            <DockPanel Margin="8,0,0,0">
                <Button x:Name="BtnClose" Content="✕" Click="BtnClose_Click"
                        DockPanel.Dock="Right" Width="32" Height="28"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="14" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" Padding="4,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnMaximize" Content="☐" Click="BtnMaximize_Click"
                        DockPanel.Dock="Right" Width="32" Height="28"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="14" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" Padding="4,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnMinimize" Content="─" Click="BtnMinimize_Click"
                        DockPanel.Dock="Right" Width="32" Height="28"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="14" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" Padding="4,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="⬛ Negativer"
                           FontSize="12" IsHitTestVisible="False"/>
            </DockPanel>
        </Border>

        <!-- Inverted content area is rendered by a separate click-through overlay window -->
        <Border Margin="4,28,4,4" Background="Transparent" IsHitTestVisible="False"/>

        <!-- Frame border -->
        <Border BorderBrush="#DD222222" BorderThickness="4,0,4,4" Margin="0,28,0,0"
                IsHitTestVisible="False"/>
    </Grid>
</Window>
